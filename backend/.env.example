APP_ENV=development
# Jika APP_ADDR dikosongkan, backend akan otomatis memakai PORT dari Railway.
APP_ADDR=:8080
APP_URL=http://localhost:8080
FRONTEND_URL=http://localhost:5173,http://127.0.0.1:5173
APP_TIMEZONE=Asia/Jakarta
EDUCATION_REFERENCE_PATH=./data/education_reference_id.json

# Railway alias MySQL seperti MYSQLHOST/MYSQLPORT/MYSQLUSER/MYSQLPASSWORD/MYSQLDATABASE juga didukung.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=hris

SESSION_SECRET=please-set-a-strong-session-secret-min-32-chars
CSRF_SECRET=please-set-a-strong-csrf-secret-min-32-chars
STORAGE_PATH=./storage
STORAGE_ENCRYPTION_KEY=
STORAGE_ENCRYPT_UPLOADS=false
REDIS_URL=
REDIS_ADDR=
REDIS_PASSWORD=
REDIS_DB=0
MAX_REQUEST_BODY_MB=25
DISABLE_BACKGROUND_WORKERS=false
COOKIE_SECURE=true

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@localhost
SMTP_TLS=false

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URL=http://localhost:5173/api/auth/google/register/callback

# Supports multiple API keys. When key 1 hits rate/token limits, auto-rotates to key 2, etc.
# Set ENABLED=false to skip a key without removing it.
GROQ_API_KEY_1=
GROQ_API_KEY_1_ENABLED=true
GROQ_API_KEY_2=
GROQ_API_KEY_2_ENABLED=true
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=openai/gpt-oss-120b
GROQ_FALLBACK_MODEL=openai/gpt-oss-20b,llama-3.3-70b-versatile,llama-3.1-8b-instant
# Set false to disable fallback and only use primary GROQ_MODEL.
GROQ_FALLBACK_ENABLED=true
# Optional: override full chain (comma separated). If set, this will be used directly.
GROQ_MODEL_CHAIN=
GROQ_TIMEOUT_SECONDS=60
# Token-per-minute budget per worker queue. Used to space AI screening jobs safely.
GROQ_TPM_LIMIT=8000
