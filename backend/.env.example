APP_ENV=development
APP_ADDR=:8080
APP_URL=http://localhost:8080
FRONTEND_URL=http://localhost:5173,http://127.0.0.1:5173
EDUCATION_REFERENCE_PATH=./data/education_reference_id.json

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=hris

SESSION_SECRET=change-me
CSRF_SECRET=change-me
STORAGE_PATH=./storage
COOKIE_SECURE=false

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@localhost
SMTP_TLS=false

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URL=http://localhost:5173/api/auth/google/register/callback

GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=openai/gpt-oss-120b
GROQ_FALLBACK_MODEL=openai/gpt-oss-20b,llama-3.3-70b-versatile,llama-3.1-8b-instant
# Optional: override full chain (comma separated). If set, this will be used directly.
GROQ_MODEL_CHAIN=
GROQ_TIMEOUT_SECONDS=60
